# QQTalker 环境配置

# OneBot WebSocket 配置 (注意：环境变量名必须用英文！)
WS_URL=ws://127.0.0.1:3001
ACCESS_TOKEN=

# AI API 配置 (支持任何OpenAI兼容接口)
# 选项1: DeepSeek (推荐，便宜好用)
AI_API_KEY=your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# 选项2: OpenAI
# AI_API_KEY=your-openai-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# 选项3: 其他兼容API（如Ollama本地模型）
# AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen2.5:7b

# 机器人配置
BOT_QQ=                  # 机器人QQ号(必须设置!)
BOT_NICKNAME=            # 机器人昵称(可选,用于识别文本@消息)
AT_TRIGGER=true          # 是否只响应@消息 (true/false)
GROUP_WHITELIST=         # 允许的群号，逗号分隔(留空允许所有群)
MAX_HISTORY=10           # 每个会话保留的最大历史消息数

# TTS语音配置（可选）
TTS_ENABLED=false        # 是否启用语音回复 (true/false)
TTS_PROVIDER=local-http  # 语音提供者：local-http / legacy-baidu
TTS_SERVICE_URL=http://127.0.0.1:8765  # 本机 Python 语音服务地址
TTS_BACKEND=gpt-sovits   # 默认语音后端：gpt-sovits / rvc-compat / edge-tts
TTS_MODEL=               # 默认模型ID（如 preset-dongxuelian / preset-yongchutafi）
TTS_MODEL_DIR=./data/voice-models  # 本地语音模型目录
TTS_VOICE=zh-CN-XiaoyiNeural  # 回退时使用的系统音色
TTS_SPEED=1.03          # 基础语速；系统会再按句型微调，推荐 0.95-1.08
TTS_STYLE=natural       # 风格/情感（如 natural / sweet / lively）
TTS_SANITIZE_WHITELIST= # 允许保留的特殊字符（逐字符），例如 ～!
TTS_SANITIZE_BLACKLIST= # 额外强制移除的特殊字符（逐字符）
TTS_PREVIEW_TEXT=你好呀，欢迎使用QQTalker语音播报插件。  # Dashboard 默认试听文本
TTS_TIMEOUT_MS=45000    # 单次合成超时
TTS_FALLBACK_TO_BAIDU=true  # 本地服务不可用时是否回退旧百度TTS
TTS_RUNTIME_POLICY=model-default # model-default / config-only
TTS_FALLBACK_CHAIN=edge-tts,legacy-baidu
TTS_LONG_TEXT_PREFERRED_BACKEND=gpt-sovits
TTS_LONG_TEXT_THRESHOLD=72
TTS_RVC_SHORT_TEXT_MAX_LENGTH=28
TTS_EXPERIMENTAL_RVC_ENABLED=false
TTS_DEFAULT_CHARACTER=永雏塔菲
TTS_CHARACTER_MODEL_MAP=永雏塔菲:preset-yongchutafi,冬雪莲:preset-dongxuelian
TTS_GROUP_VOICE_ROLE_MAP=      # 例：123456:永雏塔菲,234567:冬雪莲

# 日志配置
LOG_LEVEL=info

# 自学习插件
SELF_LEARNING_ENABLED=true
SELF_LEARNING_DATA_DIR=./data/self-learning
SELF_LEARNING_TARGETS=
SELF_LEARNING_BLACKLIST=
SELF_LEARNING_INTERVAL_HOURS=6
SELF_LEARNING_MIN_MESSAGES=30
SELF_LEARNING_MAX_BATCH=200
SELF_LEARNING_ENABLE_ML=true
SELF_LEARNING_MAX_ML_SAMPLE=120
SELF_LEARNING_TOTAL_AFFECTION_CAP=250
SELF_LEARNING_MAX_USER_AFFECTION=100
SELF_LEARNING_DB_TYPE=sqlite
SELF_LEARNING_DB_FILE=./data/self-learning/self-learning.sqlite
SELF_LEARNING_MYSQL_URL=
SELF_LEARNING_POSTGRES_URL=

# 外部插件（可选）
PLUGIN_PATHS=plugins/example-echo-plugin.cjs

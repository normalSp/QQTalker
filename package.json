{
  "name": "qq-talker",
  "version": "1.0.0",
  "description": "QQ聊天机器人 - 接入CodeBuddy AI助手",
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "pkg": "tsc && pkg . --compress GZip",
    "pkg:win": "tsc && pkg . --compress GZip -t node18-win-x64",
    "pkg:linux": "tsc && pkg . --compress GZip -t node18-linux-x64",
    "voice:training:sync": "node scripts/voice-training/sync-training-workspace.mjs",
    "voice:download": "node scripts/voice-training/download-public-sources.mjs",
    "voice:clips:suggest": "node scripts/voice-training/suggest-training-clips.mjs",
    "voice:clips": "node scripts/voice-training/export-training-clips.mjs",
    "voice:transcribe": "node scripts/voice-training/transcribe-training-clips.mjs",
    "voice:manifest": "node scripts/voice-training/build-training-manifest.mjs",
    "voice:rvc:import": "node scripts/voice-training/import-rvc-artifacts.mjs",
    "voice:eval": "node scripts/voice-training/run-ab-eval.mjs",
    "start:stack": "powershell -ExecutionPolicy Bypass -File start-voice-stack.ps1",
    "start:console": "powershell -ExecutionPolicy Bypass -File start-with-console.ps1",
    "start:bat": "start-with-console.bat"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "edge-tts": "^1.0.1",
    "mysql2": "^3.20.0",
    "openai": "^4.28.0",
    "pg": "^8.20.0",
    "pino": "^8.17.0",
    "pino-pretty": "^11.2.0",
    "silk-wasm": "^3.7.1",
    "sql.js": "^1.14.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.5.10",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  },
  "optionalDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "node_modules/silk-wasm/**/*",
      "node_modules/edge-tts/out/**/*",
      ".env*",
      "dashboard-assets/**/*",
      "log-analyzer.html",
      "log-analyzer-assets/**/*",
      "log-analyzer-advanced.js",
      "dashboard-preview.html"
    ],
    "scripts": [
      "dist/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-pkg",
    "ignores": [
      "**/*.ts",
      "**/*.map"
    ]
  }
}
